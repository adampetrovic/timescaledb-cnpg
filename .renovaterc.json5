{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":disableRateLimiting",
    ":semanticCommits",
    ":automergePr",
  ],
  dependencyDashboard: true,
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  suppressNotifications: ["prEditedNotification", "prIgnoreNotification"],
  enabledManagers: ["github-actions", "custom.regex"],
  customManagers: [
    {
      description: "Track TimescaleDB version via timescaledb-ha Docker image tags",
      customType: "regex",
      managerFilePatterns: ["build.yaml"],
      matchStrings: [
        "datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s+versioning=(?<versioning>\\S+)\\nversion:\\s+\"?(?<currentValue>[^\"\\n]+)\"?",
      ],
      extractVersionTemplate: "^pg\\d+[^-]*-ts(?<version>.+)$",
    },
  ],
  packageRules: [
    {
      description: "Auto-merge TimescaleDB updates",
      matchFileNames: ["build.yaml"],
      automerge: true,
      automergeType: "pr",
      semanticCommitScope: "timescaledb",
      semanticCommitType: "release",
    },
  ],
}
